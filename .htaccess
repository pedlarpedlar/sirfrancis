# Custom error document
ErrorDocument 404 /404.php

# Performance headers for Lighthouse/Core Web Vitals.
<IfModule mod_mime.c>
  AddType image/avif .avif
  AddType image/webp .webp
  AddType font/woff2 .woff2
  AddType font/woff .woff
  AddType font/ttf .ttf
  AddType font/otf .otf
  AddType application/vnd.ms-fontobject .eot
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml
  <FilesMatch "\.(?:html?|css|js|json|xml|svg)$">
    SetOutputFilter DEFLATE
  </FilesMatch>
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/x-javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresDefault "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  <FilesMatch "\.(?:avif|webp|jpe?g|png|gif|svg|ico|woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# Redirect old or non-existent URLs to new ones
Redirect 301 /iqaala /return_policy
Redirect 301 /iqala /return_policy
Redirect 301 /iqaalah /return_policy
Redirect 301 /iqalah /return_policy

Redirect 301 /store /products
Redirect 301 /gifts /gifting
RedirectMatch 301 ^/wholesale/?$ /wholesale-pricelist

Redirect 301 /favicon.ico /assets/img/favicon.png
Redirect 301 /favicon.png /assets/img/favicon.png


# Enable mod_rewrite
RewriteEngine on
Options +FollowSymLinks -MultiViews

# Redirect non-www to www
RewriteCond %{HTTP_HOST} ^candybird\.co\.za [NC]
RewriteRule ^(.*)$ https://www.candybird.co.za/$1 [R=301,L]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-SSL} !on
RewriteCond %{HTTP_HOST} ^candybird\.co\.za$ [OR]
RewriteCond %{HTTP_HOST} ^www\.candybird\.co\.za$
RewriteRule ^/?$ "https\:\/\/www\.candybird\.co\.za\/" [R=301,L]

# Serve a fresh XML sitemap at the standard search-engine URL.
RewriteRule ^sitemap\.xml$ /crons/generate_sitemap.php [L]

# Keep page URLs clean and resolve extensionless PHP pages before product slugs.
RewriteCond %{REQUEST_METHOD} GET [OR]
RewriteCond %{REQUEST_METHOD} HEAD
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]

# Handle 404 errors correctly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/admin-cb/ [NC]
RewriteCond %{REQUEST_URI} !^/(assets|uploads|PHPMailer|vendor|crons|emails)/ [NC]
RewriteRule ^([a-z0-9][a-z0-9-]{2,120})/?$ /route_slug.php?slug=$1 [L,QSA]

# Handle 404 errors correctly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /404.php [L]

#Redirect shop to products
RewriteCond %{HTTP_HOST} ^shop\.candybird\.co\.za$ [NC]
RewriteRule ^(.*)$ https://candybird.co.za/products [R=301,L]

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php80” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php80___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
